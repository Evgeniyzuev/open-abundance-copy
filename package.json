{
  "name": "open-abundance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "db:link": "pnpm dlx supabase link --project-ref bsikxrsguwketlloflgi",
    "db:pull": "pnpm dlx supabase db pull",
    "db:push": "pnpm dlx supabase db push",
    "db:types": "pnpm dlx supabase gen types typescript --project-id bsikxrsguwketlloflgi --schema public > lib/database.types.ts",
    "db:dump": "pnpm dlx supabase db dump --schema public -f supabase/schema.sql"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "lucide-react": "^0.554.0",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "typescript": "5.5.3"
  }
}
